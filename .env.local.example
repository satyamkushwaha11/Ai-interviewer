# Copy this file to .env.local and fill in at least one provider's API key.
#   cp .env.local.example .env.local

# --- Provider selection -------------------------------------------------------
# Force a provider: "openai" or "gemini".
# If unset, the app auto-selects OpenAI when OPENAI_API_KEY is present,
# otherwise Gemini when GEMINI_API_KEY is present.
AI_PROVIDER=

# --- OpenAI -------------------------------------------------------------------
# Required for text-to-speech regardless of AI_PROVIDER.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
OPENAI_TTS_MODEL=

# --- Gemini -------------------------------------------------------------------
# Used when AI_PROVIDER=gemini, or as a fallback when no OpenAI key is set.
# Note: gemini-2.0-flash has no free-tier quota on some keys (HTTP 429);
# gemini-2.5-flash is the recommended default.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=
